# ---------------------------------------------------------------------------
# Rust
# ---------------------------------------------------------------------------
/target/
**/target/
# NOTE: Cargo.lock is intentionally NOT ignored. This workspace ships
# binaries, so the lockfile is committed to guarantee reproducible builds.

# ---------------------------------------------------------------------------
# Node / Next.js
# ---------------------------------------------------------------------------
node_modules/
.next/
out/
dist/
coverage/
.npm/
*.tsbuildinfo

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.ruff_cache/
.pytest_cache/
.mypy_cache/
*.egg-info/

# ---------------------------------------------------------------------------
# Environment / secrets
# ---------------------------------------------------------------------------
# Secrets never get committed. Use .env.example (committed) to document
# required variables; real values live only in local, ignored .env files.
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Terraform
# ---------------------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform.lock.hcl.backup

# ---------------------------------------------------------------------------
# Helm
# ---------------------------------------------------------------------------
# Chart dependency directories and packaged charts are build artifacts.
charts/*/charts/
charts/**/*.tgz

# ---------------------------------------------------------------------------
# Editors / IDEs
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.iml

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*

# ---------------------------------------------------------------------------
# Logs and local-only files
# ---------------------------------------------------------------------------
*.log
logs/
*.local
